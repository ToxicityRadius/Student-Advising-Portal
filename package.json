{
  "name": "student-advising-portal-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "npm --prefix frontend start",
    "backend:dev": "npm --prefix backend run dev",
    "frontend:start": "npm --prefix frontend start",
    "frontend:build": "npm --prefix frontend run build",
    "prepare": "husky"
  },
  "dependencies": {
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "prettier --write",
      "eslint --fix --no-error-on-unmatched-pattern"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "prettier --write"
    ]
  }
}
