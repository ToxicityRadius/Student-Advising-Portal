{
  "name": "student-advising-portal-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "npm --prefix frontend start",
    "backend:dev": "npm --prefix backend run dev",
    "frontend:start": "npm --prefix frontend start",
    "frontend:build": "npm --prefix frontend run build",
    "lint:backend": "npx eslint backend --ext .js",
    "test:frontend:ci": "npm --prefix frontend test -- --watchAll=false",
    "test:backend": "npm --prefix backend test",
    "test:backend:integration": "npm --prefix backend run test:integration",
    "test:e2e": "npm --prefix e2e run test",
    "test:e2e:list": "npm --prefix e2e run test:list",
    "test:e2e:prod": "node e2e/scripts/run-prod-e2e.js",
    "test:e2e:prod:list": "node e2e/scripts/run-prod-e2e.js --list",
    "audit:backend:high": "node scripts/audit-backend-with-retry.js",
    "audit:backend:high:soft": "node scripts/audit-backend-with-retry.js --soft-network-fail",
    "audit:frontend:high": "npm --prefix frontend audit --omit=dev --audit-level=high",
    "verify:predeploy": "npm run lint:backend && npm --prefix frontend run build && npm run test:frontend:ci && npm run test:backend && npm run test:backend:integration && npm run audit:backend:high",
    "verify:predeploy:soft": "npm run lint:backend && npm --prefix frontend run build && npm run test:frontend:ci && npm run test:backend && npm run test:backend:integration && npm run audit:backend:high:soft",
    "verify:predeploy:e2e": "npm run verify:predeploy && npm run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "prettier --write",
      "eslint --fix --no-error-on-unmatched-pattern"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "prettier --write"
    ]
  }
}
