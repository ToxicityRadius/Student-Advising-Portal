lerna-debug.log*
*.log

# Temporary files
*.tmp
*.pid
.cache/

# E2E generated artifacts
e2e/test-results/
e2e/playwright-report/

# Database files
*.db
*.sqlite

# Environment files
.env
.env.local
.env.*.local

# Deployment guide (contains real credentials)
Deployment.md

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

